# ──────────────────────────────────────────────────────────────
# Millionaire Stocks — Local Development Environment
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to GitHub — it is in .gitignore.
# ──────────────────────────────────────────────────────────────

# Alpaca API credentials
ALPACA_ACCOUNT_NAME=your_account_name
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Use paper trading URL for testing:
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Use live trading URL when ready:
# ALPACA_BASE_URL=https://api.alpaca.markets

# ── Strategy Parameters ─────────────────────────────────────
DRY_RUN=true            # Set to false to execute real orders
ORDER_QTY=1             # Number of shares per order
STOP_LOSS_PCT=0.05      # 5% stop-loss threshold
BUY_THRESHOLD=3         # Min conditions (out of 5) to trigger BUY
MIN_VOLUME=500000       # Minimum avg daily volume filter
MAX_POSITIONS=20        # Max concurrent open positions
RATE_LIMIT_SEC=0.35     # Seconds between API calls (rate limiting)
